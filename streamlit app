import streamlit as st
import numpy as np
import pandas as pd
import pickle
import matplotlib.pyplot as plt

with open('model.pkl', 'rb') as file:
    model = pickle.load(file)

st.title('🌸 Iris Flower Prediction App')
st.write("""
### Enter the flower details to predict its species
""")

st.sidebar.header('User Input Parameters')

def user_input_features():
    sepal_length = st.sidebar.slider('Sepal Length (cm)', 4.0, 8.0, 5.4)
    sepal_width = st.sidebar.slider('Sepal Width (cm)', 2.0, 4.4, 3.4)
    petal_length = st.sidebar.slider('Petal Length (cm)', 1.0, 7.0, 1.3)
    petal_width = st.sidebar.slider('Petal Width (cm)', 0.1, 2.5, 0.2)
    data = {
        'sepal length (cm)': sepal_length,
        'sepal width (cm)': sepal_width,
        'petal length (cm)': petal_length,
        'petal width (cm)': petal_width
    }
    features = pd.DataFrame(data, index=[0])
    return features

input_df = user_input_features()

st.subheader('User Input Parameters')
st.write(input_df)

prediction = model.predict(input_df)
prediction_proba = model.predict_proba(input_df)

iris_target = ['Setosa', 'Versicolor', 'Virginica']

st.subheader('Prediction')
st.write(f'Predicted Class: **{iris_target[prediction[0]]}**')

st.subheader('Prediction Probability')
st.write(pd.DataFrame(prediction_proba, columns=iris_target))

st.subheader('Prediction Probability Bar Chart')
fig, ax = plt.subplots()
ax.bar(iris_target, prediction_proba[0], color=['#ff9999', '#66b3ff', '#99ff99'])
plt.ylabel('Probability')
plt.xlabel('Classes')
st.pyplot(fig)

st.markdown("""---""")
st.write('Made with ❤️ using Streamlit')
